{
  "id": "trade-republic-importer",
  "name": "Trade Republic Importer",
  "version": "1.0.0",
  "description": "Import Trade Republic CSV exports into Wealthfolio. Splits cash and portfolio activities across two accounts and handles internal fund transfers automatically.",
  "author": "blastik",
  "main": "dist/addon.js",
  "sdkVersion": "3.5.1",
  "enabled": true,
  "permissions": [
    {
      "category": "accounts",
      "functions": [{ "name": "getAll", "isDeclared": true, "isDetected": false }],
      "purpose": "List accounts so the user can select their cash and portfolio accounts"
    },
    {
      "category": "activities",
      "functions": [
        { "name": "checkImport", "isDeclared": true, "isDetected": false },
        { "name": "saveMany", "isDeclared": true, "isDetected": false },
        { "name": "create", "isDeclared": true, "isDetected": false },
        { "name": "update", "isDeclared": true, "isDetected": false }
      ],
      "purpose": "Validate and import activities parsed from the Trade Republic CSV"
    },
    {
      "category": "assets",
      "functions": [{ "name": "create", "isDeclared": true, "isDetected": false }],
      "purpose": "Create new asset entries for unrecognised securities during import"
    },
    {
      "category": "secrets",
      "functions": [
        { "name": "get", "isDeclared": true, "isDetected": false },
        { "name": "set", "isDeclared": true, "isDetected": false }
      ],
      "purpose": "Persist addon configuration (account selection, transfer patterns) across sessions"
    },
    {
      "category": "ui",
      "functions": [
        { "name": "sidebar.addItem", "isDeclared": true, "isDetected": false },
        { "name": "navigation.navigate", "isDeclared": true, "isDetected": false },
        { "name": "router.add", "isDeclared": true, "isDetected": false },
        { "name": "onDisable", "isDeclared": true, "isDetected": false }
      ],
      "purpose": "Add importer navigation item to sidebar and register addon routes"
    },
    {
      "category": "query",
      "functions": [{ "name": "invalidateQueries", "isDeclared": true, "isDetected": false }],
      "purpose": "Refresh host application data after import"
    },
    {
      "category": "portfolio",
      "functions": [{ "name": "update", "isDeclared": true, "isDetected": false }],
      "purpose": "Trigger portfolio recalculation after import"
    },
    {
      "category": "market-data",
      "functions": [{ "name": "searchTicker", "isDeclared": true, "isDetected": false }],
      "purpose": "Search for securities when mapping unrecognised tickers"
    }
  ],
  "keywords": ["trade-republic", "importer", "csv"],
  "license": "MIT"
}
